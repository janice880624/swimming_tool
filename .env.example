PORT=3000
JWT_SECRET=change-this-to-a-long-random-string-in-production

# PostgreSQL connection string. On Render, this is auto-filled when you link
# a Render Postgres database in the Blueprint. For local development, point
# it at a local Postgres instance, e.g.:
# DATABASE_URL=postgres://postgres:yourpassword@localhost:5432/coach_platform
DATABASE_URL=

# used only on first startup (and by `npm run seed`) to create the first admin account
SEED_ADMIN_NAME=系統管理員
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=admin1234
